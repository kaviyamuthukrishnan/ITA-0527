import cv2
import numpy as np
img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
pts1 = np.float32([[56,65], [368,52], [28,387], [389,390]])
pts2 = np.float32([[0,0], [300,0], [0,300], [300,300]])
matrix = cv2.getPerspectiveTransform(pts1, pts2)
perspective = cv2.warpPerspective(img, matrix, (300,300))
img_resized = cv2.resize(img, (300,300))
combined = np.hstack((img_resized, perspective))
cv2.imshow("Input (Left) | Perspective Output (Right)", combined)
cv2.waitKey(0)
cv2.destroyAllWindows()
