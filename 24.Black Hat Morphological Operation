import cv2
import numpy as np

img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

kernel = np.ones((9,9), np.uint8)

blackhat = cv2.morphologyEx(gray, cv2.MORPH_BLACKHAT, kernel)

result = np.hstack((gray, blackhat))

cv2.imshow("Black Hat - Input and Output", result)
cv2.waitKey(0)
cv2.destroyAllWindows()
