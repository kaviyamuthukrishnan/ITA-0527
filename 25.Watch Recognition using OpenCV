import cv2
import numpy as np

img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/images.jpg")

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
gray_blur = cv2.GaussianBlur(gray,(9,9),2)

circles = cv2.HoughCircles(gray_blur, cv2.HOUGH_GRADIENT,1,50,
                           param1=50,param2=30,
                           minRadius=20,maxRadius=200)

output = img.copy()

if circles is not None:
    circles = np.uint16(np.around(circles))
    for i in circles[0,:]:
        cv2.circle(output,(i[0],i[1]),i[2],(0,255,0),3)
        cv2.putText(output,"Watch Detected",(i[0]-40,i[1]-40),
                    cv2.FONT_HERSHEY_SIMPLEX,0.7,(0,255,0),2)

result = np.hstack((img, output))

cv2.imshow("Watch Detection", result)
cv2.waitKey(0)
cv2.destroyAllWindows()
