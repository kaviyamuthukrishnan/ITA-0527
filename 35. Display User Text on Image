import cv2

img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/Screenshots/input.png")

text = input("Enter text: ")

output = img.copy()

cv2.putText(output,text,(50,100),cv2.FONT_HERSHEY_SIMPLEX,2,(0,0,255),3)

img = cv2.resize(img,(500,400))
output = cv2.resize(output,(500,400))

combined = cv2.hconcat([img,output])

cv2.imshow("Input Image | Text Output",combined)

cv2.waitKey(0)
cv2.destroyAllWindows()
