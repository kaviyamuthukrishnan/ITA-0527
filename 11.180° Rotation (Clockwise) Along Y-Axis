import cv2
import numpy as np
img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
flip_y = cv2.flip(img, 1)
rotated = cv2.rotate(flip_y, cv2.ROTATE_180)
combined = np.hstack((img, rotated))
cv2.imshow("Input (Left) | 180 Rotation Output (Right)", combined)
cv2.waitKey(0)
cv2.destroyAllWindows()
