import cv2
import numpy as np
img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
kernel = np.ones((5,5), np.uint8)
eroded = cv2.erode(img, kernel, iterations=1)
eroded = cv2.resize(eroded, (img.shape[1], img.shape[0]))
combined = np.hstack((img, eroded))
cv2.imshow("Original Image (Left) | Eroded Image (Right)", combined)
cv2.waitKey(0)
cv2.destroyAllWindows()
