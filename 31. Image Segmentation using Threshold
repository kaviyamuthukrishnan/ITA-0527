import cv2

img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/Screenshots/input.png")

gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

ret, thresh = cv2.threshold(gray,127,255,cv2.THRESH_BINARY)

thresh = cv2.cvtColor(thresh, cv2.COLOR_GRAY2BGR)

img = cv2.resize(img,(500,400))
thresh = cv2.resize(thresh,(500,400))

combined = cv2.hconcat([img,thresh])

cv2.imshow("Input Image | Segmented Image",combined)

cv2.waitKey(0)
cv2.destroyAllWindows()
