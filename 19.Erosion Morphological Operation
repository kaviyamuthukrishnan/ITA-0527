import cv2
import numpy as np
img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
kernel = np.ones((5,5), np.uint8)
erosion = cv2.erode(gray, kernel, iterations=1)
erosion_colored = cv2.cvtColor(erosion, cv2.COLOR_GRAY2BGR)
combined = np.hstack((img, erosion_colored))
cv2.imshow("Input (Left) | Erosion Output (Right)", combined)
cv2.waitKey(0)
cv2.destroyAllWindows()
