import cv2
import numpy as np
img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
rows, cols = img.shape[:2]
pts1 = np.float32([[50, 50], [200, 50], [50, 200]])
pts2 = np.float32([[10, 100], [200, 50], [100, 250]])
matrix = cv2.getAffineTransform(pts1, pts2)
affine = cv2.warpAffine(img, matrix, (cols, rows))
affine_resized = cv2.resize(affine, (cols, rows))
combined = np.hstack((img, affine_resized))
cv2.imshow("Input (Left) | Affine Output (Right)", combined)
cv2.waitKey(0)
cv2.destroyAllWindows()
