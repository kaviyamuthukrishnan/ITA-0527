import cv2
import numpy as np
img = cv2.imread("C:/Users/KAVIYA_MUTHUKRISHNAN/Pictures/input.jpg")
kernel = np.ones((5,5), np.uint8)
dilated = cv2.dilate(img, kernel, iterations=1)
dilated = cv2.resize(dilated, (img.shape[1], img.shape[0]))
combined = np.hstack((img, dilated))
cv2.imshow("Original Image (Left) | Dilated Image (Right)", combined)
cv2.waitKey(0)
cv2.destroyAllWindows()
