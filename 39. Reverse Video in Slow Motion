import cv2

cap = cv2.VideoCapture("C:/Users/KAVIYA_MUTHUKRISHNAN/Downloads/7687600-uhd_2160_3840_30fps.mp4")

frames = []

# Read all frames
while True:
    ret, frame = cap.read()
    if not ret:
        break
    frames.append(frame)

cap.release()

# Reverse frames
reverse_frames = frames[::-1]

for i in range(len(reverse_frames)):

    original = cv2.resize(frames[i], (800, 450))
    reverse = cv2.resize(reverse_frames[i], (800, 450))

    cv2.imshow("Input Video (Original)", original)
    cv2.imshow("Output Video (Reverse Slow Motion)", reverse)

    # Slow motion
    if cv2.waitKey(80) & 0xFF == 27:
        break

cv2.destroyAllWindows()
